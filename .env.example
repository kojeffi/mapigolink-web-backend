SECRET_KEY=mapigo-link-super-secret-key-change-in-production-2024
DEBUG=True
ALLOWED_HOSTS=*

# --- DATABASE ---
# SQLite (default, zero config — great for local dev & presentations)
DB_ENGINE=sqlite

# PostgreSQL (uncomment + fill in for production)
# DB_ENGINE=postgresql
# DB_NAME=mapigolink_db
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- REDIS (optional, only needed for Celery background tasks) ---
# REDIS_URL=redis://localhost:6379/0
